# IMPORTING BASIC LIBRARIES

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# OPENING THE CSV FILE

df = pd.read_csv("smartcart_customers.csv")
df.head()

# DATA PREPROCESSING

df.shape
df.isnull().sum()          # Checking for Null Values 

# HANDELLING MISSING VALUES

df["Income"] = df["Income"].fillna(df["Income"].median())

# FEATURE ENGINEERING

df["Age"] = 2026-df["Year_Birth"]    # Age

df["Dt_Customer"] = pd.to_datetime(df["Dt_Customer"], dayfirst=True)      # Customer Joining Date

reference_date = df["Dt_Customer"].max()

df["Customer_Tenure_Days"] = (reference_date - df["Dt_Customer"]).dt.days

df["Total_Children"] = df["Kidhome"] + df["Teenhome"]   # Children

df["Education"] = df["Education"].replace({"Basic": "Undergraduate",   # Education
                                          "Graduation" : "Graduate",
                                          "2n Cycle": "Undergraduate",
                                          "Master": "Postgraduate",
                                          "PhD": "Postgraduate"})

# Marital Status

df["Living_With"] = df["Marital_Status"].replace({
    "Married": "Partner", "Together": "Partner",
    "Single": "Alone", "Divorced": "Alone",
    "Widow": "Alone", "Absurd": "Alone", "YOLO": "Alone"
})

## DROPPING UNNECESSARY COLUMNS

cols_to_drop = ["ID", "Year_Birth", "Marital_Status", "Kidhome", "Teenhome", "Dt_Customer","MntWines", "MntFruits",
    "MntMeatProducts", "MntFishProducts", "MntSweetProducts", "MntGoldProds"]
df_cleaned = df.drop(columns = cols_to_drop)
df_cleaned.head()
